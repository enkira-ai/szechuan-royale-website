ont-style: italic;\n  color: #D4AF37;\n  font-size: 0.9375rem;\n  letter-spacing: 0.02em;\n}\n\n/* ======== MENU ITEM (legacy) ======== */\n.menu-item {\n  transition: background-color 0.2s ease, border-color 0.2s ease;\n  border-bottom: 1px solid rgba(212,175,55,0.08);\n}\n.menu-item:hover {\n  background-color: rgba(204,17,0,0.06);\n}\n\n/* ======== HOVER LINK UTILITIES ======== */\n.link-gold {\n  color: #D4AF37;\n  text-decoration: none;\n  transition: color 0.2s ease;\n}\n.link-gold:hover { color: #F0C040; }\n\n.link-stone {\n  color: #8A7968;\n  text-decoration: none;\n  transition: color 0.2s ease;\n  letter-spacing: 0.05em;\n}\n.link-stone:hover { color: #D4AF37; }\n\n.link-phone {\n  color: #D4AF37;\n  text-decoration: none;\n  transition: color 0.2s ease;\n}\n.link-phone:hover { color: #F0C040; }\n\n/* Order banner button - gold */\n.btn-banner-primary {\n  display: inline-block;\n  background: #D4AF37;\n  color: #0d0806;\n  padding: 0.875rem 2.5rem;\n  font-family: 'Noto Sans SC', sans-serif;\n  font-weight: 600;\n  font-size: 0.875rem;\n  letter-spacing: 0.1em;\n  text-transform: uppercase;\n  text-decoration: none;\n  transition: background-color 0.25s ease, transform 0.2s ease, box-shadow 0.25s ease;\n}\n.btn-banner-primary:hover {\n  background: #F0C040;\n  transform: translateY(-1px);\n  box-shadow: 0 6px 24px rgba(0,0,0,0.3);\n}\n\n/* Order banner secondary links */\n.btn-banner-secondary {\n  display: inline-block;\n  border: 1px solid rgba(245,230,200,0.3);\n  color: rgba(245,230,200,0.75);\n  padding: 0.5rem 1.125rem;\n  font-size: 0.8rem;\n  font-family: 'Noto Sans SC', sans-serif;\n  letter-spacing: 0.05em;\n  text-decoration: none;\n  transition: border-color 0.2s ease, color 0.2s ease;\n}\n.btn-banner-secondary:hover {\n  border-color: rgba(245,230,200,0.7);\n  color: #F5E6C8;\n}\n\n/* Gallery border hover */\n.gallery-frame {\n  border: 1px solid rgba(212,175,55,0.12);\n  transition: border-color 0.3s ease;\n}\n.gallery-frame:hover {\n  bord